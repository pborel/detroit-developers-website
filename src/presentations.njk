---
layout: base.njk
title: Presentations
breadcrumb: presentations.html
permalink: /presentations/
---

{% if collections.draftPresentations.length %}
<div id="drafts-section" class="content-section" style="display: none;">
  <div class="line-gutter" aria-hidden="true">1<br>2<br>3</div>
  <div class="section-content">
    <div class="section-comment">// DRAFTS</div>

    <div style="display: flex; flex-direction: column; gap: 12px; max-width: 700px;">
      {% for pres in collections.draftPresentations %}
        <a href="{{ pres.url }}" class="card" style="display: flex; justify-content: space-between; align-items: center; text-decoration: none; border-left: 3px solid var(--peach);">
          <div>
            <div class="card-title" style="color: var(--peach);">{{ pres.data.title }}</div>
            <div class="card-meta">
              {% if pres.data.slideTotal %}{{ pres.data.slideTotal }} slides{% endif %}
            </div>
          </div>
          <span style="color: var(--subtext0); font-size: 18px; flex-shrink: 0; margin-left: 16px;">→</span>
        </a>
      {% endfor %}
    </div>
  </div>
</div>
{% endif %}

<div class="content-section">
  <div class="line-gutter" aria-hidden="true">1<br>2<br>3<br>4<br>5</div>
  <div class="section-content">
    <div class="section-comment">// ALL PRESENTATIONS</div>

    {% if collections.presentations.length %}
      <div style="display: flex; flex-direction: column; gap: 12px; max-width: 700px;">
        {% for pres in collections.presentations %}
          <a href="{{ pres.url }}" class="card" style="display: flex; justify-content: space-between; align-items: center; text-decoration: none;">
            <div>
              <div class="card-title">{{ pres.data.title }}</div>
              <div class="card-meta">
                {% if pres.data.slideTotal %}{{ pres.data.slideTotal }} slides{% endif %}
              </div>
            </div>
            <span style="color: var(--subtext0); font-size: 18px; flex-shrink: 0; margin-left: 16px;">→</span>
          </a>
        {% endfor %}
      </div>
    {% else %}
      <p style="color: var(--subtext0);">No presentations yet. Check back soon!</p>
    {% endif %}
  </div>
</div>

<script>
  const params = new URLSearchParams(window.location.search);
  if (params.get('draft') === 'true' || params.get('drafts') === 'true') {
    const el = document.getElementById('drafts-section');
    if (el) el.style.display = '';
  }
</script>
