<script>
(function () {
  const slides = Array.from(document.querySelectorAll('.slide'));
  const total = slides.length;
  let current = 0;

  function getHashIndex() {
    const n = parseInt(window.location.hash.replace('#', ''), 10);
    return (!isNaN(n) && n >= 1 && n <= total) ? n - 1 : 0;
  }

  function showSlide(index) {
    slides[current].classList.remove('active');
    current = Math.max(0, Math.min(total - 1, index));
    slides[current].classList.add('active');
    history.replaceState(null, '', '#' + (current + 1));
  }

  function applyStep(el) {
    var mode = el.getAttribute('data-step');
    if (mode === 'outline') {
      el.style.outline = '2px solid #fab387';
      el.style.outlineOffset = '4px';
      el.style.borderRadius = '4px';
      el.style.width = 'fit-content';
      el.style.maxWidth = '100%';
      var body = el.querySelector('.step-body');
      if (body) body.style.display = '';
    } else {
      el.style.textDecoration = 'line-through';
      el.style.opacity = '0.4';
    }
  }

  function clearStep(el) {
    var mode = el.getAttribute('data-step');
    if (mode === 'outline') {
      el.style.outline = '';
      el.style.outlineOffset = '';
      el.style.borderRadius = '';
      el.style.width = '';
      el.style.maxWidth = '';
      var body = el.querySelector('.step-body');
      if (body) body.style.display = 'none';
    } else {
      el.style.textDecoration = '';
      el.style.opacity = '';
    }
  }

  function advance() {
    var slide = slides[current];
    var pendingStep = slide.querySelector('[data-step]:not(.step-done)');
    if (pendingStep) {
      pendingStep.classList.add('step-done');
      applyStep(pendingStep);
      return;
    }
    if (current < total - 1) showSlide(current + 1);
  }

  function retreat() {
    var slide = slides[current];
    var doneSteps = Array.from(slide.querySelectorAll('[data-step].step-done'));
    if (doneSteps.length > 0) {
      var last = doneSteps[doneSteps.length - 1];
      last.classList.remove('step-done');
      clearStep(last);
      return;
    }
    if (current > 0) showSlide(current - 1);
  }

  showSlide(getHashIndex());

  document.addEventListener('keydown', function (e) {
    if (e.key === 'ArrowRight' || e.key === 'ArrowDown' || e.key === ' ' || e.key === 'PageDown') {
      e.preventDefault();
      advance();
    } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp' || e.key === 'PageUp') {
      e.preventDefault();
      retreat();
    }
  });

  document.addEventListener('click', function (e) {
    if (e.target.closest('a') || e.target.closest('button')) return;
    advance();
  });

  window.addEventListener('hashchange', function () {
    showSlide(getHashIndex());
  });
})();
</script>
